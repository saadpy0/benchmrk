generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CREATOR
  BRAND
  ADMIN
  MODERATOR
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum CampaignStatus {
  DRAFT
  PENDING_REVIEW
  LIVE
  PAUSED
  COMPLETED
  REJECTED
}

enum SubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  VERIFIED
  APPROVED
  REJECTED
  PAID
}

enum Platform {
  INSTAGRAM
  YOUTUBE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creatorProfile CreatorProfile?
  brandProfile   BrandProfile?
}

model CreatorProfile {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  displayName     String
  bio             String?
  kycStatus       KycStatus @default(NOT_STARTED)
  reputationScore Float     @default(0)
  createdAt       DateTime  @default(now())

  applications Application[]
  submissions  ContentSubmission[]
  wallet       EarningsWallet?
}

model BrandProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  companyName String
  gstNumber   String?
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  campaigns Campaign[]
}

model Campaign {
  id          String         @id @default(uuid())
  brandId     String
  brand       BrandProfile   @relation(fields: [brandId], references: [id])
  title       String
  description String
  guidelines  String
  cpvRate     Decimal
  totalBudget Decimal
  status      CampaignStatus @default(DRAFT)
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime       @default(now())

  applications Application[]
  submissions  ContentSubmission[]
}

model Application {
  id         String         @id @default(uuid())
  campaignId String
  campaign   Campaign       @relation(fields: [campaignId], references: [id])
  creatorId  String
  creator    CreatorProfile @relation(fields: [creatorId], references: [id])
  status     String         @default("PENDING")
  createdAt  DateTime       @default(now())

  @@unique([campaignId, creatorId])
}

model ContentSubmission {
  id            String           @id @default(uuid())
  campaignId    String
  campaign      Campaign         @relation(fields: [campaignId], references: [id])
  creatorId     String
  creator       CreatorProfile   @relation(fields: [creatorId], references: [id])
  platform      Platform
  contentUrl    String
  status        SubmissionStatus @default(SUBMITTED)
  brandFeedback String?

  verifiedViews Int?
  lastCheckedAt DateTime?
  fraudScore    Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model EarningsWallet {
  id              String   @id @default(uuid())
  creatorId       String   @unique
  creator         CreatorProfile @relation(fields: [creatorId], references: [id])
  balance         Decimal  @default(0)
  totalEarned     Decimal  @default(0)
  updatedAt       DateTime @updatedAt

  payouts         Payout[]
}

model Payout {
  id              String        @id @default(uuid())
  walletId        String
  wallet          EarningsWallet @relation(fields: [walletId], references: [id])
  amount          Decimal
  status          PayoutStatus  @default(PENDING)
  upiId           String?
  bankAccount     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}