generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CREATOR
  BRAND
  ADMIN
  MODERATOR
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum CampaignStatus {
  DRAFT
  PENDING_REVIEW
  LIVE
  PAUSED
  COMPLETED
  REJECTED
}

enum SubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  VERIFIED
  APPROVED
  REJECTED
  PAID
}

enum Platform {
  INSTAGRAM
  YOUTUBE
}

enum BalanceEntryType {
  ACCRUAL_PENDING
  RELEASE_TO_AVAILABLE
  WITHDRAWAL
  REVERSAL
  MANUAL_ADJUSTMENT
}

enum BalanceEntryStatus {
  PENDING
  AVAILABLE
  RELEASED
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creatorProfile   CreatorProfile?
  brandProfile     BrandProfile?
  connectedAccounts ConnectedPlatformAccount[]
}

model CreatorProfile {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  displayName     String
  bio             String?
  kycStatus       KycStatus @default(NOT_STARTED)
  reputationScore Float     @default(0)
  createdAt       DateTime  @default(now())

  applications Application[]
  submissions  ContentSubmission[]
  baselines    CreatorBaseline[]
  wallet       CreatorWallet?
}

model ConnectedPlatformAccount {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  platform          Platform
  providerAccountId String
  channelTitle      String?
  publishedAt       DateTime?
  subscriberCount   Int?
  uploadsPlaylistId String?
  accessToken       String?
  refreshToken      String?
  scopes            String?
  tokenType         String?
  tokenExpiresAt    DateTime?
  isPrimary         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([platform, providerAccountId])
  @@index([userId, platform])
}

model BrandProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  companyName String
  gstNumber   String?
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  campaigns Campaign[]
}

model Campaign {
  id          String         @id @default(uuid())
  brandId     String
  brand       BrandProfile   @relation(fields: [brandId], references: [id])
  title       String
  description String
  guidelines  String
  cpvRate     Decimal
  totalBudget Decimal
  status      CampaignStatus @default(DRAFT)
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime       @default(now())

  applications Application[]
  submissions  ContentSubmission[]
}

model Application {
  id         String         @id @default(uuid())
  campaignId String
  campaign   Campaign       @relation(fields: [campaignId], references: [id])
  creatorId  String
  creator    CreatorProfile @relation(fields: [creatorId], references: [id])
  status     String         @default("PENDING")
  createdAt  DateTime       @default(now())

  @@unique([campaignId, creatorId])
}

model ContentSubmission {
  id            String           @id @default(uuid())
  campaignId    String
  campaign      Campaign         @relation(fields: [campaignId], references: [id])
  creatorId     String
  creator       CreatorProfile   @relation(fields: [creatorId], references: [id])
  platform      Platform
  contentUrl    String
  status        SubmissionStatus @default(SUBMITTED)
  brandFeedback String?

  verifiedViews Int?
  lastCheckedAt DateTime?
  fraudScore    Float?

  metricSnapshots MetricSnapshot[]
  balanceEntries  BalanceLedgerEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CreatorBaseline {
  id                String         @id @default(uuid())
  creatorId         String
  creator           CreatorProfile @relation(fields: [creatorId], references: [id])
  platform          Platform
  sampleSize        Int            @default(30)
  avgViews          Float
  avgLikes          Float
  avgComments       Float
  avgEngagementRate Float
  followerCount     Int?
  audienceIndiaPct  Float?
  computedAt        DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([creatorId, platform])
}

model MetricSnapshot {
  id                 String            @id @default(uuid())
  submissionId       String
  submission         ContentSubmission @relation(fields: [submissionId], references: [id])
  capturedAt         DateTime          @default(now())
  viewCount          Int
  likeCount          Int?
  commentCount       Int?
  shareCount         Int?
  engagementRatio    Float?
  geographicIndiaPct Float?

  @@index([submissionId, capturedAt])
}

model CreatorWallet {
  id               String               @id @default(uuid())
  creatorId        String               @unique
  creator          CreatorProfile       @relation(fields: [creatorId], references: [id])
  pendingBalance   Decimal              @default(0)
  availableBalance Decimal              @default(0)
  lifetimeEarned   Decimal              @default(0)
  entries          BalanceLedgerEntry[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model BalanceLedgerEntry {
  id           String             @id @default(uuid())
  walletId     String
  wallet       CreatorWallet      @relation(fields: [walletId], references: [id])
  submissionId String?
  submission   ContentSubmission? @relation(fields: [submissionId], references: [id])
  entryType    BalanceEntryType
  status       BalanceEntryStatus @default(PENDING)
  amount       Decimal
  holdUntil    DateTime?
  notes        String?
  createdAt    DateTime           @default(now())
  releasedAt   DateTime?

  @@index([walletId, createdAt])
  @@index([submissionId])
}
